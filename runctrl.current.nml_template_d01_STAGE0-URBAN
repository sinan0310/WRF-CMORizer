&globalvars
   activity_id = "DD",
   contact = "meteo@unican.es",
   Conventions = "CF-1.11",
   domain_id = "EUR-12",
   att_domain = "Europe",
   driving_experiment_id = "evaluation",
   driving_experiment = "reanalysis simulation of the recent past",
   driving_institution_id = "ECMWF",
   driving_source_id = "ERA5",
   driving_variant_label = "r1i1p1f1",
   grid = "Lambert conic conformal with 12 km grid spacing",
   institution = "UCAN [Instituto de Fisica de Cantabria (IFCA), CSIC-Universidad de Cantabria, Santander, Spain]",
   institution_id = "UCAN", 
   license = "https://cordex.org/data-access/cordex-cmip6-data/cordex-cmip6-terms-of-use",
   mip_era = "CMIP6",
   product = "model-output",  
   project_id = "FPS-URB-RCC",
   source = "Weather Research and Forecasting model version 4.5.1, CORDEX WRF Community configuration R",
   source_id = "WRF451R-CTRL",
   source_type = "ARCM",
   version = "v20240820",
   version_realization = "v1-r1",
   references = "https://github.com/CORDEX-WRF-community/fps-urb-rcc/tree/main/STAGE-0",
   comment = "ERA5 r1i1p1f1 driven simulation for the FPS-URBAN EUR-12 domain using WRF v4.5.1.4-R, CTRL setting. This simulation was carried out on the HPC infrastructure of the Instituto de Fisica de Cantabria (IFCA), CSIC-Universidad de Cantabria. We acknowledge the support from the Advanced Computing and e-Science group at IFCA.",
/   

&filesystem
   DirInputSimResRoot = "../",
   DirOutputPostProRoot = "set-full-path-to-output",
   domain = "d01",
   calendar = "standard",
/
&model_config
   ts = '0000',         										! 2020 can be used for pattern matching with filenames, set to '0000' to use all files that are found
   te = '0000',         										! 2020 can be used for pattern matching with filenames, set to '0000' to use all files that are found
   nx = 456,                            		! domain_id raw output x-dim, incl. relaxation zone, unstaggered
   ny = 439,                            		! domain_id raw output x-dim, incl. relaxation zone, unstaggered
   nz = 59,                         				! number of vertical levels, unstaggered
   npl = 6,         												! number of pressure levels in wrfpress file
   xoffset = 9,                             ! zone to be cut away in x-dir. (e.g., boundary relax zone) spec_bdy_width
   yoffset = 9,                             ! many grps do not remove the boundary relaxation zone, in agreement with UCAN boundary relaxation zone is removed
   xfocus = 436,                            ! EUR-11 official grid x-dim, unknown from geo_em file, nx-2*xoffset
   yfocus = 419,                            ! EUR-11 official grid y-dim, unknown from geo_em file, ny-2*yoffset
   tstot = '1950-01-01_00:00:00',           ! start of the main time vector, per protocol, do not change
   tetot = '2101-01-01_00:00:00',           ! end of the main time vector, do not change
/
&static_fields
   PnFnGeo = 'set-full-path-to-geo_em.d01.nc',
   projection = 'LCC', !'ROT'
/
&tool_config
   nvar = 1,
   aggregation_yearly = .F.,              	! for tier-2 / initial processing, default CMOR, 1hr 3hr data are stored in yearly files, data controls files created
   aggregation_monthly = .F.,             	! data controls monthly files created
   aggregation_individually = .T.,      	  ! individual file is created, for the timespan as defined below
   tsact = '2020-03-01_00:00:00',         	! tsact and teact are only needed if aggregation_individually = .TRUE.,
   teact = '2020-08-31_23:00:00',         	! set 1 timestep less - since extra timestep is needed for accumulated variables. Othewise, the last timestep will be filled with missing values.
/

